rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write to gtt_raw_data collection
    // (Auth is disabled in the app; the cron pipeline and in-app
    //  Firestore write-back both need unauthenticated write access)
    match /gtt_raw_data/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // App configuration (teams, seniors, new hires)
    match /gtt_app_config/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
